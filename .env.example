# ===========================================================================
# Agent ECHO — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` in the project root AND a duplicate copy to
# `backend/.env` (the backend reads from backend/.env, the mobile app reads
# from the repo-root .env.local via Expo's EXPO_PUBLIC_* convention).
#
#   cp .env.example .env.local
#   cp .env.example backend/.env
#
# Only the keys you actually use need real values — leave the rest blank and
# the corresponding feature will gracefully degrade into demo/mock mode.
# ===========================================================================


# ---------------------------------------------------------------------------
# 1. OpenAI  (REQUIRED for transcription, smart actions, summaries, ASL vision)
# ---------------------------------------------------------------------------
# Get one at:  https://platform.openai.com/api-keys
# Needs access to:   whisper-1, gpt-4o, gpt-4o-mini, tts-1, gpt-4o vision
OPENAI_API_KEY=sk-REPLACE_ME


# ---------------------------------------------------------------------------
# 2. Anthropic Claude  (optional fallback planning agent)
# ---------------------------------------------------------------------------
# Get one at:  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# ---------------------------------------------------------------------------
# 3. Twilio  (REQUIRED for Emergency SMS + Trusted Circle alerts)
# ---------------------------------------------------------------------------
# Sign up:            https://www.twilio.com/try-twilio
# Console:            https://console.twilio.com/
# You need to buy (or use the trial) one SMS-capable phone number.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555550123


# ---------------------------------------------------------------------------
# 4. Hume AI  (optional — vocal emotion / prosody tags in Conversation mode)
# ---------------------------------------------------------------------------
# Get one at:  https://beta.hume.ai/settings/keys
HUME_API_KEY=


# ---------------------------------------------------------------------------
# 5. Google Maps  (REQUIRED for spatial direction + evacuation routing)
# ---------------------------------------------------------------------------
# Create a project at:  https://console.cloud.google.com/
# Enable "Maps SDK for Android", "Maps SDK for iOS", "Geocoding API",
# "Directions API", then generate a key at:
#   https://console.cloud.google.com/google/maps-apis/credentials
# The EXPO_PUBLIC_* copy is required because Expo only exposes env vars with
# that prefix to the mobile bundle.
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ---------------------------------------------------------------------------
# 6. Firebase Cloud Messaging  (optional — Night Mode push alerts)
# ---------------------------------------------------------------------------
# Create at:  https://console.firebase.google.com/
# Project settings → Cloud Messaging → Server key (legacy) OR V1 credentials.
FIREBASE_PROJECT_ID=
FIREBASE_SERVER_KEY=


# ---------------------------------------------------------------------------
# 7. Backend <-> Mobile connection
# ---------------------------------------------------------------------------
# The host/port your mobile device can reach the backend on.
# Android emulator → 10.0.2.2,  iOS sim → localhost,  physical device → your
# machine's LAN IP (e.g. 192.168.1.42).
BACKEND_PORT=4000
EXPO_PUBLIC_API_URL=http://localhost:4000


# ---------------------------------------------------------------------------
# 8. Postgres  (optional — event/history persistence. Falls back to in-memory)
# ---------------------------------------------------------------------------
DATABASE_URL=


# ---------------------------------------------------------------------------
# 9. Misc
# ---------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
